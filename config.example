# hotspot-proxy-toggle config 예시

NETWORK_SERVICE=''
WIFI_DEVICE=''

# 필수. socks5 또는 http를 지원함.
PROXY_TYPE=socks5

# 필수. 휴대폰이 핫스팟 라우터 IP 위에서 proxy를 여는 port.
PROXY_PORT=1080

# 필수. 정확히 매칭할 단일 휴대폰 핫스팟 SSID.
HOTSPOT_SSID=''

# macOS proxy setting을 켜기 전에 endpoint 확인을 요구함.
# socks5는 no-auth handshake를 확인하고, http는 HTTP 응답 형식을 확인함.
REQUIRE_PROXY_CHECK=1
PROXY_CHECK_TIMEOUT=3

# 최종 reconciliation state가 바뀌거나 실제 proxy setting 변경이 있을 때
# macOS notification을 표시함.
NOTIFY_ON_CHANGE=0

# auto, en, ko를 지원함. auto는 macOS 언어 설정을 사용함.
LANGUAGE=auto
