#!/bin/bash
set -euo pipefail

CONFIG_PATH="${HOTSPOT_PROXY_CONFIG:-$HOME/.config/hotspot-proxy-toggle.conf}"
LOG_PATH="${HOTSPOT_PROXY_LOG:-$HOME/Library/Logs/hotspot-proxy-toggle.log}"
STATE_PATH="${HOTSPOT_PROXY_STATE:-$HOME/Library/Application Support/hotspot-proxy-toggle/state}"
UI_STATE_PATH="${HOTSPOT_PROXY_UI_STATE:-$HOME/Library/Application Support/hotspot-proxy-toggle/status.json}"
NOTIFICATION_SENDER="${HOTSPOT_NOTIFICATION_SENDER:-$HOME/Applications/MHP.app/Contents/MacOS/hotspot-proxy-toggle-menu}"

NETWORK_SERVICE="${NETWORK_SERVICE:-}"
WIFI_DEVICE="${WIFI_DEVICE:-}"
HOTSPOT_SSID="${HOTSPOT_SSID:-}"
PROXY_TYPE="${PROXY_TYPE:-socks5}"
PROXY_PORT="${PROXY_PORT:-}"
REQUIRE_PROXY_CHECK="${REQUIRE_PROXY_CHECK:-1}"
PROXY_CHECK_TIMEOUT="${PROXY_CHECK_TIMEOUT:-3}"
DRY_RUN="${DRY_RUN:-0}"
NOTIFY_ON_CHANGE="${NOTIFY_ON_CHANGE:-0}"
LANGUAGE="${LANGUAGE:-}"
NOTIFICATION_LOCALE="${NOTIFICATION_LOCALE:-}"
PROXY_STATE_CHANGED=0

usage() {
  cat <<'EOF'
Usage:
  hotspot-proxy-toggle run
  hotspot-proxy-toggle status
  hotspot-proxy-toggle evaluate
  hotspot-proxy-toggle off

Config:
  ~/.config/hotspot-proxy-toggle.conf

Required:
  PROXY_TYPE=socks5|http
  PROXY_PORT=1080

Optional:
  HOTSPOT_SSID='My Phone'
  REQUIRE_PROXY_CHECK=1
  PROXY_CHECK_TIMEOUT=3
  NETWORK_SERVICE='Wi-Fi' # override only; auto-detected by default
  WIFI_DEVICE='en0'
  DRY_RUN=1
  NOTIFY_ON_CHANGE=1
  LANGUAGE=auto
  HOTSPOT_PROXY_STATE="$HOME/Library/Application Support/hotspot-proxy-toggle/state"
  HOTSPOT_PROXY_UI_STATE="$HOME/Library/Application Support/hotspot-proxy-toggle/status.json"
  HOTSPOT_NOTIFICATION_SENDER="$HOME/Applications/MHP.app/Contents/MacOS/hotspot-proxy-toggle-menu"
EOF
}

log() {
  /bin/mkdir -p "$(/usr/bin/dirname "$LOG_PATH")"
  printf '%s %s\n' "$(/bin/date '+%Y-%m-%d %H:%M:%S')" "$*" >>"$LOG_PATH"
}

load_config() {
  if [[ -f "$CONFIG_PATH" ]]; then
    load_config_file "$CONFIG_PATH"
  fi

  NETWORK_SERVICE="${NETWORK_SERVICE:-}"
  WIFI_DEVICE="${WIFI_DEVICE:-}"
  HOTSPOT_SSID="${HOTSPOT_SSID:-}"
  PROXY_TYPE="${PROXY_TYPE:-socks5}"
  PROXY_PORT="${PROXY_PORT:-}"
  REQUIRE_PROXY_CHECK="${REQUIRE_PROXY_CHECK:-1}"
  PROXY_CHECK_TIMEOUT="${PROXY_CHECK_TIMEOUT:-3}"
  DRY_RUN="${DRY_RUN:-0}"
  NOTIFY_ON_CHANGE="${NOTIFY_ON_CHANGE:-0}"
  LANGUAGE="${LANGUAGE:-${NOTIFICATION_LOCALE:-auto}}"
  if [[ "$LANGUAGE" != "auto" ]]; then
    NOTIFICATION_LOCALE="$LANGUAGE"
  else
    NOTIFICATION_LOCALE="${NOTIFICATION_LOCALE:-auto}"
  fi
  STATE_PATH="${HOTSPOT_PROXY_STATE:-${STATE_PATH:-$HOME/Library/Application Support/hotspot-proxy-toggle/state}}"
  UI_STATE_PATH="${HOTSPOT_PROXY_UI_STATE:-${UI_STATE_PATH:-$HOME/Library/Application Support/hotspot-proxy-toggle/status.json}}"
  NOTIFICATION_SENDER="${HOTSPOT_NOTIFICATION_SENDER:-${NOTIFICATION_SENDER:-$HOME/Applications/MHP.app/Contents/MacOS/hotspot-proxy-toggle-menu}}"
}

load_config_file() {
  local path="$1"
  local line trimmed key raw value

  while IFS= read -r line || [[ -n "$line" ]]; do
    trimmed="$(trim "$line")"
    [[ -z "$trimmed" || "$trimmed" == \#* ]] && continue
    [[ "$trimmed" == *=* ]] || continue

    key="$(trim "${trimmed%%=*}")"
    raw="$(trim "${trimmed#*=}")"
    [[ "$key" =~ ^[A-Z_][A-Z0-9_]*$ ]] || continue
    value="$(parse_config_value "$raw")"

    case "$key" in
      NETWORK_SERVICE) NETWORK_SERVICE="$value" ;;
      WIFI_DEVICE) WIFI_DEVICE="$value" ;;
      HOTSPOT_SSID) HOTSPOT_SSID="$value" ;;
      PROXY_TYPE) PROXY_TYPE="$value" ;;
      PROXY_PORT) PROXY_PORT="$value" ;;
      REQUIRE_PROXY_CHECK) REQUIRE_PROXY_CHECK="$value" ;;
      PROXY_CHECK_TIMEOUT) PROXY_CHECK_TIMEOUT="$value" ;;
      DRY_RUN) DRY_RUN="$value" ;;
      NOTIFY_ON_CHANGE) NOTIFY_ON_CHANGE="$value" ;;
      LANGUAGE) LANGUAGE="$value" ;;
      NOTIFICATION_LOCALE) NOTIFICATION_LOCALE="$value" ;;
      HOTSPOT_PROXY_STATE) STATE_PATH="$value" ;;
      HOTSPOT_PROXY_UI_STATE) UI_STATE_PATH="$value" ;;
      HOTSPOT_NOTIFICATION_SENDER) NOTIFICATION_SENDER="$value" ;;
    esac
  done <"$path"
}

parse_config_value() {
  local raw="$1"
  local value

  if [[ "${#raw}" -ge 2 && "$raw" == \'* && "$raw" == *\' ]]; then
    value="${raw:1:${#raw}-2}"
    value="${value//\'\\\'\'/\'}"
    printf '%s' "$value"
    return 0
  fi

  if [[ "${#raw}" -ge 2 && "$raw" == \"* && "$raw" == *\" ]]; then
    value="${raw:1:${#raw}-2}"
    value="${value//\\\"/\"}"
    value="${value//\\\\/\\}"
    printf '%s' "$value"
    return 0
  fi

  value="${raw//\\ / }"
  printf '%s' "$value"
}

validate_config() {
  case "$PROXY_TYPE" in
    socks5|http) ;;
    *)
      printf 'unsupported PROXY_TYPE: %s (supported: socks5, http)\n' "$PROXY_TYPE" >&2
      return 64
      ;;
  esac

  case "$NOTIFICATION_LOCALE" in
    auto|en|ko) ;;
    *)
      printf 'unsupported NOTIFICATION_LOCALE: %s (supported: auto, en, ko)\n' "$NOTIFICATION_LOCALE" >&2
      return 64
      ;;
  esac

  case "$LANGUAGE" in
    auto|en|ko) ;;
    *)
      printf 'unsupported LANGUAGE: %s (supported: auto, en, ko)\n' "$LANGUAGE" >&2
      return 64
      ;;
  esac
}

run_cmd() {
  if [[ "$DRY_RUN" == "1" ]]; then
    printf 'DRY_RUN:'
    printf ' %q' "$@"
    printf '\n'
    log "DRY_RUN: $*"
    return 0
  fi
  "$@"
}

wifi_device_from_hardware_ports() {
  /usr/sbin/networksetup -listallhardwareports |
    /usr/bin/awk '
      /^Hardware Port: Wi-Fi$/ { in_wifi = 1; next }
      /^Hardware Port:/ { in_wifi = 0 }
      in_wifi && /^Device:/ { print $2; exit }
    '
}

wifi_network_service_from_device() {
  local dev="$1"

  /usr/sbin/networksetup -listnetworkserviceorder |
    /usr/bin/awk -v dev="$dev" '
      /^\([0-9]+\) / {
        service = $0
        sub(/^\([0-9]+\) /, "", service)
        sub(/^\*/, "", service)
        next
      }
      index($0, "Device: " dev ")") > 0 {
        print service
        exit
      }
    '
}

ensure_network_service() {
  local wifi_dev="${WIFI_DEVICE:-}"
  local service

  if [[ -n "$NETWORK_SERVICE" ]]; then
    return 0
  fi

  if [[ -z "$wifi_dev" ]]; then
    wifi_dev="$(wifi_device_from_hardware_ports)"
  fi

  if [[ -z "$wifi_dev" ]]; then
    log "network service unavailable: no Wi-Fi device"
    return 1
  fi

  service="$(wifi_network_service_from_device "$wifi_dev")"
  if [[ -z "$service" ]]; then
    log "network service unavailable for Wi-Fi device $wifi_dev"
    return 1
  fi

  WIFI_DEVICE="$wifi_dev"
  NETWORK_SERVICE="$service"
}

default_interface() {
  /sbin/route -n get default 2>/dev/null |
    /usr/bin/awk '/interface:/ { print $2; exit }'
}

ipconfig_summary() {
  local dev="$1"
  /usr/sbin/ipconfig getsummary "$dev" 2>/dev/null || true
}

extract_summary_field() {
  local field="$1"
  /usr/bin/awk -v field="$field" -F' : ' '
    {
      key = $1
      gsub(/^[ \t]+|[ \t]+$/, "", key)
      if (key == field) {
        print $2
        exit
      }
    }
  '
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

csv_contains_exact() {
  local csv="$1"
  local needle="$2"
  local old_ifs="$IFS"
  local item

  IFS=','
  for item in $csv; do
    item="$(trim "$item")"
    if [[ "$item" == "$needle" ]]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

csv_marker_in_text() {
  local csv="$1"
  local text="$2"
  local old_ifs="$IFS"
  local item

  IFS=','
  for item in $csv; do
    item="$(trim "$item")"
    if [[ -n "$item" && "$text" == *"$item"* ]]; then
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

current_socks5_proxy_state() {
  /usr/sbin/networksetup -getsocksfirewallproxy "$NETWORK_SERVICE"
}

current_http_proxy_state() {
  printf 'Web Proxy:\n'
  /usr/sbin/networksetup -getwebproxy "$NETWORK_SERVICE"
  printf 'Secure Web Proxy:\n'
  /usr/sbin/networksetup -getsecurewebproxy "$NETWORK_SERVICE"
}

current_proxy_state() {
  case "$PROXY_TYPE" in
    socks5) current_socks5_proxy_state ;;
    http) current_http_proxy_state ;;
  esac
}

socks5_proxy_available() {
  local host="$1"
  local port="$2"
  local response

  response="$(
    set +e +o pipefail
    printf '\005\001\000' |
      /usr/bin/nc -G "$PROXY_CHECK_TIMEOUT" -w "$PROXY_CHECK_TIMEOUT" "$host" "$port" 2>/dev/null |
      /bin/dd bs=2 count=1 2>/dev/null |
      /usr/bin/od -An -tx1 |
      /usr/bin/tr -d ' \n'
  )"

  [[ "$response" == "0500" ]]
}

http_proxy_available() {
  local host="$1"
  local port="$2"
  local first_line

  first_line="$(
    set +e +o pipefail
    printf 'GET http://127.0.0.1/ HTTP/1.1\r\nHost: 127.0.0.1\r\nConnection: close\r\n\r\n' |
      /usr/bin/nc -G "$PROXY_CHECK_TIMEOUT" -w "$PROXY_CHECK_TIMEOUT" "$host" "$port" 2>/dev/null |
      /usr/bin/head -n 1 |
      /usr/bin/tr -d '\r'
  )"

  case "$first_line" in
    HTTP/*" 407 "*) return 1 ;;
    HTTP/*) return 0 ;;
    *) return 1 ;;
  esac
}

proxy_endpoint_available() {
  local host="$1"
  local port="$2"

  case "$PROXY_TYPE" in
    socks5) socks5_proxy_available "$host" "$port" ;;
    http) http_proxy_available "$host" "$port" ;;
  esac
}

proxy_check_ok_label() {
  case "$PROXY_TYPE" in
    socks5) printf 'socks5-ok' ;;
    http) printf 'http-ok' ;;
  esac
}

proxy_check_missing_label() {
  case "$PROXY_TYPE" in
    socks5) printf 'socks5-missing' ;;
    http) printf 'http-missing' ;;
  esac
}

proxy_display_name() {
  case "$PROXY_TYPE" in
    socks5) printf 'SOCKS5' ;;
    http) printf 'HTTP' ;;
  esac
}

mark_proxy_changed() {
  PROXY_STATE_CHANGED=1
}

apple_script_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

notification_state_changed() {
  local state_key="$1"
  local previous_state=""

  if [[ "$PROXY_STATE_CHANGED" == "1" ]]; then
    return 0
  fi

  if [[ -f "$STATE_PATH" ]]; then
    previous_state="$(<"$STATE_PATH")"
  fi

  [[ "$previous_state" != "$state_key" ]]
}

write_notification_state() {
  local state_key="$1"

  /bin/mkdir -p "$(/usr/bin/dirname "$STATE_PATH")" || {
    log "notification state write skipped: failed to create state directory"
    return 0
  }
  printf '%s\n' "$state_key" >"$STATE_PATH" ||
    log "notification state write failed: $STATE_PATH"
}

resolve_notification_locale() {
  local lang locale

  case "$NOTIFICATION_LOCALE" in
    en|ko)
      printf '%s' "$NOTIFICATION_LOCALE"
      return 0
      ;;
  esac

  lang="$(
    /usr/bin/defaults read -g AppleLanguages 2>/dev/null |
      /usr/bin/awk -F'[", ]+' '
        {
          for (i = 1; i <= NF; i++) {
            if ($i ~ /^[A-Za-z][A-Za-z]([-_][A-Za-z0-9]+)?$/) {
              print $i
              exit
            }
          }
        }
      '
  )"
  locale="$(/usr/bin/defaults read -g AppleLocale 2>/dev/null || true)"

  case "$lang:$locale" in
    ko*:*|*:ko*) printf 'ko' ;;
    *) printf 'en' ;;
  esac
}

notification_title() {
  local kind="$1"
  local locale

  locale="$(resolve_notification_locale)"
  case "$locale:$kind" in
    ko:on) printf '✅ 핫스팟 프록시 켜짐' ;;
    ko:unavailable) printf '⚠️ 핫스팟 프록시 사용 불가' ;;
    ko:idle) printf 'ℹ️ 핫스팟 대기' ;;
    en:on) printf '✅ Hotspot Proxy On' ;;
    en:unavailable) printf '⚠️ Hotspot Proxy Unavailable' ;;
    en:idle) printf 'ℹ️ Hotspot Proxy Idle' ;;
  esac
}

active_notification_body() {
  case "$(resolve_notification_locale)" in
    ko) printf '현재 트래픽이 핫스팟 프록시를 사용합니다.' ;;
    *) printf 'Traffic is using the hotspot proxy.' ;;
  esac
}

unavailable_notification_body() {
  case "$(resolve_notification_locale)" in
    ko) printf '핫스팟은 감지됐지만 프록시 서버가 응답하지 않습니다.' ;;
    *) printf 'Hotspot detected, but the proxy server is not responding.' ;;
  esac
}

inactive_notification_body() {
  local result="$1"
  local locale

  locale="$(resolve_notification_locale)"
  if [[ "$locale" == "ko" ]]; then
    case "$result" in
      status=not-hotspot*) printf '현재 Wi-Fi는 설정한 핫스팟이 아닙니다.' ;;
      *) printf '핫스팟이 활성 상태가 아닙니다.' ;;
    esac
    return 0
  fi

  case "$result" in
    status=not-hotspot*) printf 'Current Wi-Fi is not a configured hotspot.' ;;
    *) printf 'Hotspot is not active.' ;;
  esac
}

send_macos_notification() {
  local title="$1"
  local body="$2"
  local escaped_title escaped_body

  if [[ -x "$NOTIFICATION_SENDER" ]] &&
     "$NOTIFICATION_SENDER" --notify --title "$title" --body "$body" >/dev/null 2>&1; then
    return 0
  fi

  if [[ ! -x /usr/bin/osascript ]]; then
    log "notification skipped: osascript not found"
    return 0
  fi

  escaped_title="$(apple_script_escape "$title")"
  escaped_body="$(apple_script_escape "$body")"

  /usr/bin/osascript \
    -e "display notification \"$escaped_body\" with title \"$escaped_title\"" \
    >/dev/null 2>&1 ||
    log "notification failed: $title"
}

notify_reconcile_change() {
  local state_key="$1"
  local subtitle="$2"
  local body="$3"

  if [[ "$NOTIFY_ON_CHANGE" != "1" || "$DRY_RUN" == "1" ]]; then
    return 0
  fi

  if notification_state_changed "$state_key"; then
    send_macos_notification "$subtitle" "$body"
  fi

  write_notification_state "$state_key"
}

record_reconcile_state() {
  local state_key="$1"

  if [[ "$NOTIFY_ON_CHANGE" != "1" || "$DRY_RUN" == "1" ]]; then
    return 0
  fi

  write_notification_state "$state_key"
}

write_ui_state() {
  local kind="$1"
  local detail="${2:-}"
  local tmp

  if [[ "$DRY_RUN" == "1" ]]; then
    return 0
  fi

  /bin/mkdir -p "$(/usr/bin/dirname "$UI_STATE_PATH")" || {
    log "ui state write skipped: failed to create state directory"
    return 0
  }

  tmp="$UI_STATE_PATH.$$"
  if {
    printf '{\n'
    printf '  "version": 1,\n'
    printf '  "kind": "%s",\n' "$kind"
    printf '  "proxy_type": "%s",\n' "$PROXY_TYPE"
    printf '  "detail": "%s",\n' "$detail"
    printf '  "updated_at": "%s"\n' "$(/bin/date -u '+%Y-%m-%dT%H:%M:%SZ')"
    printf '}\n'
  } >"$tmp" && /bin/mv "$tmp" "$UI_STATE_PATH"; then
    return 0
  fi

    log "ui state write failed: $UI_STATE_PATH"
}

socks5_proxy_state_matches() {
  local router="$1"
  local current

  current="$(current_socks5_proxy_state)"
  if printf '%s\n' "$current" | /usr/bin/grep -q '^Enabled: Yes$' &&
     printf '%s\n' "$current" | /usr/bin/grep -q "^Server: $router$" &&
     printf '%s\n' "$current" | /usr/bin/grep -q "^Port: $PROXY_PORT$"; then
    return 0
  fi

  return 1
}

http_single_proxy_state_matches() {
  local state="$1"
  local router="$2"

  if printf '%s\n' "$state" | /usr/bin/grep -q '^Enabled: Yes$' &&
     printf '%s\n' "$state" | /usr/bin/grep -q "^Server: $router$" &&
     printf '%s\n' "$state" | /usr/bin/grep -q "^Port: $PROXY_PORT$"; then
    return 0
  fi

  return 1
}

set_socks5_proxy_on() {
  local router="$1"

  if socks5_proxy_state_matches "$router"; then
    log "already enabled SOCKS5 proxy for $router:$PROXY_PORT"
    return 0
  fi

  run_cmd /usr/sbin/networksetup -setsocksfirewallproxy "$NETWORK_SERVICE" "$router" "$PROXY_PORT"
  run_cmd /usr/sbin/networksetup -setsocksfirewallproxystate "$NETWORK_SERVICE" on
  mark_proxy_changed
  log "enabled SOCKS proxy for $NETWORK_SERVICE via $router:$PROXY_PORT"
}

set_http_proxy_on() {
  local router="$1"
  local web secure changed=0

  web="$(/usr/sbin/networksetup -getwebproxy "$NETWORK_SERVICE")"
  secure="$(/usr/sbin/networksetup -getsecurewebproxy "$NETWORK_SERVICE")"

  if http_single_proxy_state_matches "$web" "$router" &&
     http_single_proxy_state_matches "$secure" "$router"; then
    log "already enabled HTTP proxy for $router:$PROXY_PORT"
    return 0
  fi

  if ! http_single_proxy_state_matches "$web" "$router"; then
    run_cmd /usr/sbin/networksetup -setwebproxy "$NETWORK_SERVICE" "$router" "$PROXY_PORT"
    run_cmd /usr/sbin/networksetup -setwebproxystate "$NETWORK_SERVICE" on
    changed=1
  fi

  if ! http_single_proxy_state_matches "$secure" "$router"; then
    run_cmd /usr/sbin/networksetup -setsecurewebproxy "$NETWORK_SERVICE" "$router" "$PROXY_PORT"
    run_cmd /usr/sbin/networksetup -setsecurewebproxystate "$NETWORK_SERVICE" on
    changed=1
  fi

  if [[ "$changed" == "1" ]]; then
    mark_proxy_changed
    log "enabled HTTP proxy for $NETWORK_SERVICE via $router:$PROXY_PORT"
  fi
}

set_proxy_on() {
  local router="$1"

  case "$PROXY_TYPE" in
    socks5)
      set_http_proxy_off
      set_socks5_proxy_on "$router"
      ;;
    http)
      set_socks5_proxy_off
      set_http_proxy_on "$router"
      ;;
  esac
}

set_socks5_proxy_off() {
  local current

  current="$(current_socks5_proxy_state)"
  if printf '%s\n' "$current" | /usr/bin/grep -q '^Enabled: No$'; then
    log "already disabled"
    return 0
  fi

  run_cmd /usr/sbin/networksetup -setsocksfirewallproxystate "$NETWORK_SERVICE" off
  mark_proxy_changed
  log "disabled SOCKS proxy for $NETWORK_SERVICE"
}

set_http_proxy_off() {
  local web secure changed=0

  web="$(/usr/sbin/networksetup -getwebproxy "$NETWORK_SERVICE")"
  secure="$(/usr/sbin/networksetup -getsecurewebproxy "$NETWORK_SERVICE")"

  if ! printf '%s\n' "$web" | /usr/bin/grep -q '^Enabled: No$'; then
    run_cmd /usr/sbin/networksetup -setwebproxystate "$NETWORK_SERVICE" off
    changed=1
  fi

  if ! printf '%s\n' "$secure" | /usr/bin/grep -q '^Enabled: No$'; then
    run_cmd /usr/sbin/networksetup -setsecurewebproxystate "$NETWORK_SERVICE" off
    changed=1
  fi

  if [[ "$changed" == "0" ]]; then
    log "already disabled HTTP proxy"
    return 0
  fi

  mark_proxy_changed
  log "disabled HTTP proxy for $NETWORK_SERVICE"
}

set_proxy_off() {
  case "$PROXY_TYPE" in
    socks5) set_socks5_proxy_off ;;
    http) set_http_proxy_off ;;
  esac
}

set_all_supported_proxies_off() {
  set_socks5_proxy_off
  set_http_proxy_off
}

evaluate() {
  local wifi_dev="${WIFI_DEVICE:-}"
  local def_if summary router ssid reason

  if [[ -z "$wifi_dev" ]]; then
    wifi_dev="$(wifi_device_from_hardware_ports)"
  fi

  if [[ -z "$wifi_dev" ]]; then
    printf 'status=not-wifi reason=no-wifi-device\n'
    return 2
  fi
  WIFI_DEVICE="$wifi_dev"

  def_if="$(default_interface)"
  if [[ "$def_if" != "$wifi_dev" ]]; then
    printf 'status=not-wifi wifi_device=%s default_interface=%s\n' "$wifi_dev" "${def_if:-none}"
    return 1
  fi

  summary="$(ipconfig_summary "$wifi_dev")"
  router="$(printf '%s\n' "$summary" | extract_summary_field Router)"
  ssid="$(printf '%s\n' "$summary" | extract_summary_field SSID)"

  if [[ -z "$router" ]]; then
    printf 'status=no-router wifi_device=%s ssid=%q\n' "$wifi_dev" "${ssid:-unknown}"
    return 1
  fi

  reason="no-match"

  if [[ -z "$HOTSPOT_SSID" ]]; then
    reason="no-hotspot-ssid"
  elif [[ -n "$ssid" && "$ssid" == "$HOTSPOT_SSID" ]]; then
    reason="ssid"
    printf 'status=hotspot reason=%s wifi_device=%s router=%s ssid=%q\n' "$reason" "$wifi_dev" "$router" "${ssid:-unknown}"
    return 0
  fi

  printf 'status=not-hotspot wifi_device=%s router=%s ssid=%q reason=%s\n' "$wifi_dev" "$router" "${ssid:-unknown}" "$reason"
  return 1
}

router_from_evaluation() {
  /usr/bin/sed -n 's/.* router=\([^ ]*\).*/\1/p'
}

do_evaluate() {
  load_config
  validate_config
  evaluate
}

do_status() {
  local result rc router

  load_config
  validate_config
  set +e
  result="$(evaluate)"
  rc="$?"
  set -e
  printf '%s\n' "$result"

  if [[ "$rc" == "0" && -n "$PROXY_PORT" && "$REQUIRE_PROXY_CHECK" == "1" ]]; then
    router="$(printf '%s\n' "$result" | router_from_evaluation)"
    if proxy_endpoint_available "$router" "$PROXY_PORT"; then
      printf 'proxy_check=%s router=%s port=%s\n' "$(proxy_check_ok_label)" "$router" "$PROXY_PORT"
    else
      printf 'proxy_check=%s router=%s port=%s\n' "$(proxy_check_missing_label)" "$router" "$PROXY_PORT"
    fi
  fi

  if ensure_network_service; then
    current_proxy_state
  else
    printf 'network_service=unavailable\n'
  fi
}

do_run() {
  local result rc router

  PROXY_STATE_CHANGED=0
  load_config
  validate_config
  if [[ -z "$PROXY_PORT" ]]; then
    log "PROXY_PORT is required"
    printf 'PROXY_PORT is required\n' >&2
    return 64
  fi

  set +e
  result="$(evaluate)"
  rc="$?"
  set -e
  printf '%s\n' "$result"

  if [[ "$rc" != "0" ]]; then
    ensure_network_service || {
      write_ui_state error network_service_unavailable
      record_reconcile_state "off:$PROXY_TYPE:$result:network-service-unavailable"
      printf 'status=network-service-unavailable action=none\n'
      return 0
    }
    set_all_supported_proxies_off
    case "$result" in
      status=not-hotspot*)
        write_ui_state idle
        notify_reconcile_change "off:$PROXY_TYPE:$result" "$(notification_title idle)" "$(inactive_notification_body "$result")"
        ;;
      status=not-wifi*)
        write_ui_state not_wifi
        record_reconcile_state "off:$PROXY_TYPE:$result"
        ;;
      status=no-router*)
        write_ui_state not_wifi no_router
        record_reconcile_state "off:$PROXY_TYPE:$result"
        ;;
      *)
        write_ui_state error
        record_reconcile_state "off:$PROXY_TYPE:$result"
        ;;
    esac
    return 0
  fi

  router="$(printf '%s\n' "$result" | router_from_evaluation)"
  if [[ "$REQUIRE_PROXY_CHECK" == "1" ]] && ! proxy_endpoint_available "$router" "$PROXY_PORT"; then
    printf 'status=proxy-unavailable proxy_type=%s router=%s port=%s action=off\n' "$PROXY_TYPE" "$router" "$PROXY_PORT"
    log "$(proxy_display_name) proxy unavailable at $router:$PROXY_PORT"
    ensure_network_service || {
      write_ui_state error network_service_unavailable
      record_reconcile_state "off:$PROXY_TYPE:$result:proxy-unavailable:network-service-unavailable"
      printf 'status=network-service-unavailable action=none\n'
      return 0
    }
    set_all_supported_proxies_off
    write_ui_state unavailable
    notify_reconcile_change "off:$PROXY_TYPE:$result:proxy-unavailable" "$(notification_title unavailable)" "$(unavailable_notification_body)"
    return 0
  fi

  ensure_network_service || {
    write_ui_state error network_service_unavailable
    record_reconcile_state "on:$PROXY_TYPE:$result:network-service-unavailable"
    printf 'status=network-service-unavailable action=none\n'
    return 0
  }
  set_proxy_on "$router"
  write_ui_state on
  notify_reconcile_change "on:$PROXY_TYPE:$result" "$(notification_title on)" "$(active_notification_body)"
}

do_off() {
  PROXY_STATE_CHANGED=0
  load_config
  validate_config
  ensure_network_service || {
    write_ui_state error network_service_unavailable
    record_reconcile_state "off:$PROXY_TYPE:manual:network-service-unavailable"
    printf 'status=network-service-unavailable action=none\n'
    return 0
  }
  set_all_supported_proxies_off
  write_ui_state off manual
  record_reconcile_state "off:$PROXY_TYPE:manual"
  printf 'status=off action=off\n'
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    run) do_run ;;
    status) do_status ;;
    evaluate) do_evaluate ;;
    off) do_off ;;
    -h|--help|help|"") usage ;;
    *)
      usage >&2
      return 64
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
